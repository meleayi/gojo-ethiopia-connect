// =============================================================
// GOJO MARKETPLACE — PRISMA SCHEMA
// =============================================================
// NestJS + Prisma + PostgreSQL
// Designed for millions of users, agents, multi-vendor, Alibaba-scale
// =============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// =============================================================
// ENUMS
// =============================================================

enum UserRole {
  BUYER
  SELLER
  AGENT
  ADMIN
  MODERATOR
}

enum UserStatus {
  ACTIVE
  PENDING
  SUSPENDED
  BANNED
}

enum CompanyStatus {
  PENDING
  ACTIVE
  SUSPENDED
  REJECTED
}

enum CompanyVerificationStatus {
  PENDING
  UNDER_REVIEW
  APPROVED
  REJECTED
}

enum AgentPermission {
  MANAGE_PRODUCTS
  MANAGE_ORDERS
  MANAGE_FINANCES
  MANAGE_MESSAGES
  VIEW_ANALYTICS
  MANAGE_AGENTS
  FULL_ACCESS
}

enum ProductStatus {
  DRAFT
  PENDING
  APPROVED
  REJECTED
  ARCHIVED
}

enum ListingType {
  SALE
  RENT
  SERVICE
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PAID
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
  REFUNDED
  DISPUTED
}

enum PaymentStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  REFUNDED
  PARTIALLY_REFUNDED
}

enum PaymentMethod {
  TELEBIRR
  CBE_BIRR
  AMOLE
  CHAPA
  BANK_TRANSFER
  CASH_ON_DELIVERY
}

enum ShipmentStatus {
  PENDING
  PICKED_UP
  IN_TRANSIT
  OUT_FOR_DELIVERY
  DELIVERED
  RETURNED
  FAILED
}

enum MessageStatus {
  SENT
  DELIVERED
  READ
}

enum NotificationType {
  MESSAGE
  ORDER
  APPROVAL
  REJECTION
  REVIEW
  SELLER_VERIFICATION
  SYSTEM
  PROMOTION
}

enum SettlementStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

enum DisputeStatus {
  OPEN
  UNDER_REVIEW
  RESOLVED_BUYER
  RESOLVED_SELLER
  ESCALATED
  CLOSED
}

// =============================================================
// AUTH MODULE — Users, Roles, Sessions
// =============================================================

model User {
  id                String      @id @default(uuid()) @db.Uuid
  email             String      @unique
  emailVerified     Boolean     @default(false) @map("email_verified")
  phone             String?     @unique
  phoneVerified     Boolean     @default(false) @map("phone_verified")
  passwordHash      String      @map("password_hash")
  fullName          String?     @map("full_name")
  avatarUrl         String?     @map("avatar_url")
  preferredLanguage String      @default("en") @map("preferred_language")
  status            UserStatus  @default(PENDING)
  lastLoginAt       DateTime?   @map("last_login_at")
  createdAt         DateTime    @default(now()) @map("created_at")
  updatedAt         DateTime    @updatedAt @map("updated_at")

  // Relations
  roles          UserRoleAssignment[]
  addresses      Address[]
  orders         Order[]
  reviews        Review[]
  wishlistItems  WishlistItem[]
  cartItems      CartItem[]
  notifications  Notification[]
  searchQueries  SearchQuery[]
  productViews   ProductView[]
  agentProfiles  CompanyAgent[]
  sentMessages   Message[]       @relation("sender")
  conversations1 Conversation[]  @relation("buyer")
  conversations2 Conversation[]  @relation("seller_user")
  sessions       UserSession[]
  auditLogs      AuditLog[]

  @@index([email])
  @@index([phone])
  @@index([status])
  @@index([createdAt])
  @@map("users")
}

model UserRoleAssignment {
  id     String   @id @default(uuid()) @db.Uuid
  userId String   @map("user_id") @db.Uuid
  role   UserRole

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, role])
  @@index([userId])
  @@map("user_roles")
}

model UserSession {
  id           String   @id @default(uuid()) @db.Uuid
  userId       String   @map("user_id") @db.Uuid
  token        String   @unique
  ipAddress    String?  @map("ip_address")
  userAgent    String?  @map("user_agent")
  companyId    String?  @map("company_id") @db.Uuid  // If acting as agent
  expiresAt    DateTime @map("expires_at")
  createdAt    DateTime @default(now()) @map("created_at")

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  company Company? @relation(fields: [companyId], references: [id])

  @@index([userId])
  @@index([token])
  @@index([expiresAt])
  @@map("user_sessions")
}

// =============================================================
// COMPANY MODULE — Companies, Agents, Verification
// =============================================================

model Company {
  id              String        @id @default(uuid()) @db.Uuid
  ownerId         String        @map("owner_id") @db.Uuid
  companyName     String        @map("company_name")
  slug            String        @unique
  description     String?       @db.Text
  logoUrl         String?       @map("logo_url")
  bannerUrl       String?       @map("banner_url")
  businessEmail   String        @map("business_email")
  phone           String
  website         String?
  companyAddress  String        @map("company_address")
  city            String
  region          String?
  country         String        @default("Ethiopia")
  postalCode      String?       @map("postal_code")
  taxId           String?       @map("tax_id")
  businessLicense String?       @map("business_license")
  yearsInBusiness Int?          @map("years_in_business")
  status          CompanyStatus @default(PENDING)
  isVerified      Boolean       @default(false) @map("is_verified")
  rating          Float         @default(0)
  totalProducts   Int           @default(0) @map("total_products")
  totalSales      Int           @default(0) @map("total_sales")
  totalRevenue    Decimal       @default(0) @map("total_revenue") @db.Decimal(15, 2)
  responseTimeH   Int           @default(24) @map("response_time_hours")
  socialLinks     Json?         @map("social_links")
  certifications  Json?
  approvedAt      DateTime?     @map("approved_at")
  approvedBy      String?       @map("approved_by") @db.Uuid
  suspendedAt     DateTime?     @map("suspended_at")
  suspendReason   String?       @map("suspend_reason")
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")

  // Relations
  agents         CompanyAgent[]
  products       Product[]
  subOrders      SubOrder[]
  settlements    Settlement[]
  verification   CompanyVerification?
  sessions       UserSession[]
  bankAccounts   CompanyBankAccount[]
  disputes       Dispute[]

  @@index([ownerId])
  @@index([status])
  @@index([city])
  @@index([isVerified])
  @@index([slug])
  @@index([createdAt])
  @@map("companies")
}

model CompanyAgent {
  id          String             @id @default(uuid()) @db.Uuid
  companyId   String             @map("company_id") @db.Uuid
  userId      String             @map("user_id") @db.Uuid
  title       String?            // e.g. "Sales Manager"
  permissions AgentPermission[]
  isActive    Boolean            @default(true) @map("is_active")
  invitedBy   String?            @map("invited_by") @db.Uuid
  joinedAt    DateTime           @default(now()) @map("joined_at")
  createdAt   DateTime           @default(now()) @map("created_at")
  updatedAt   DateTime           @updatedAt @map("updated_at")

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([companyId, userId])
  @@index([companyId])
  @@index([userId])
  @@map("company_agents")
}

model CompanyVerification {
  id                String                    @id @default(uuid()) @db.Uuid
  companyId         String                    @unique @map("company_id") @db.Uuid
  status            CompanyVerificationStatus @default(PENDING)
  businessLicenseUrl String?                  @map("business_license_url")
  taxCertificateUrl  String?                  @map("tax_certificate_url")
  idDocumentUrl      String?                  @map("id_document_url")
  addressProofUrl    String?                  @map("address_proof_url")
  additionalDocs     Json?                    @map("additional_docs")
  reviewedBy         String?                  @map("reviewed_by") @db.Uuid
  reviewNote         String?                  @map("review_note") @db.Text
  reviewedAt         DateTime?                @map("reviewed_at")
  submittedAt        DateTime                 @default(now()) @map("submitted_at")
  createdAt          DateTime                 @default(now()) @map("created_at")
  updatedAt          DateTime                 @updatedAt @map("updated_at")

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([status])
  @@map("company_verifications")
}

model CompanyBankAccount {
  id            String  @id @default(uuid()) @db.Uuid
  companyId     String  @map("company_id") @db.Uuid
  bankName      String  @map("bank_name")
  accountName   String  @map("account_name")
  accountNumber String  @map("account_number")
  isPrimary     Boolean @default(false) @map("is_primary")
  createdAt     DateTime @default(now()) @map("created_at")

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@map("company_bank_accounts")
}

// =============================================================
// PRODUCT MODULE — Categories, Products, Variants, Attributes
// =============================================================

model Category {
  id           String    @id @default(uuid()) @db.Uuid
  parentId     String?   @map("parent_id") @db.Uuid
  name         String
  nameAmharic  String    @default("") @map("name_amharic")
  slug         String    @unique
  description  String?   @db.Text
  icon         String?
  imageUrl     String?   @map("image_url")
  sortOrder    Int       @default(0) @map("sort_order")
  isActive     Boolean   @default(true) @map("is_active")
  productCount Int       @default(0) @map("product_count")
  // SEO
  metaTitle    String?   @map("meta_title")
  metaDesc     String?   @map("meta_description")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  parent   Category?  @relation("CategoryTree", fields: [parentId], references: [id])
  children Category[] @relation("CategoryTree")
  products Product[]
  attributeTemplates CategoryAttribute[]

  @@index([parentId])
  @@index([slug])
  @@index([sortOrder])
  @@map("categories")
}

model CategoryAttribute {
  id         String   @id @default(uuid()) @db.Uuid
  categoryId String   @map("category_id") @db.Uuid
  name       String   // e.g. "Color", "Size", "Material"
  type       String   @default("text") // text, number, select, multiselect
  options    Json?    // For select types: ["Red", "Blue", "Green"]
  isRequired Boolean  @default(false) @map("is_required")
  sortOrder  Int      @default(0) @map("sort_order")

  category Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@index([categoryId])
  @@map("category_attributes")
}

model Product {
  id               String        @id @default(uuid()) @db.Uuid
  companyId        String        @map("company_id") @db.Uuid
  categoryId       String        @map("category_id") @db.Uuid
  name             String
  slug             String        @unique
  description      String?       @db.Text
  shortDescription String?       @map("short_description")
  price            Decimal       @db.Decimal(12, 2)
  originalPrice    Decimal?      @map("original_price") @db.Decimal(12, 2)
  currency         String        @default("ETB")
  listingType      ListingType   @default(SALE) @map("listing_type")
  rentPeriod       String?       @map("rent_period") // daily, weekly, monthly
  status           ProductStatus @default(DRAFT)
  condition        String        @default("new") // new, used, refurbished
  brand            String?
  model            String?
  sku              String?       @unique
  barcode          String?
  inStock          Boolean       @default(true) @map("in_stock")
  stockQuantity    Int           @default(0) @map("stock_quantity")
  lowStockThreshold Int          @default(5) @map("low_stock_threshold")
  minOrderQuantity  Int          @default(1) @map("min_order_quantity")
  maxOrderQuantity  Int?         @map("max_order_quantity")
  weightKg         Decimal?      @map("weight_kg") @db.Decimal(8, 3)
  dimensions       Json?         // { length, width, height, unit }
  specs            Json?         // Flexible key-value specifications
  tags             String[]
  location         String        @default("")
  city             String        @default("")
  // Metrics (denormalized for performance)
  rating           Float         @default(0)
  reviewCount      Int           @default(0) @map("review_count")
  viewCount        Int           @default(0) @map("view_count")
  wishlistCount    Int           @default(0) @map("wishlist_count")
  orderCount       Int           @default(0) @map("order_count")
  // Promotions
  isFeatured       Boolean       @default(false) @map("is_featured")
  isFlashDeal      Boolean       @default(false) @map("is_flash_deal")
  flashDealEndsAt  DateTime?     @map("flash_deal_ends_at")
  badge            String?       // "bestseller", "new", "hot"
  // Approval
  approvedAt       DateTime?     @map("approved_at")
  approvedBy       String?       @map("approved_by") @db.Uuid
  rejectionNote    String?       @map("rejection_note") @db.Text
  // SEO
  metaTitle        String?       @map("meta_title")
  metaDescription  String?       @map("meta_description")
  createdAt        DateTime      @default(now()) @map("created_at")
  updatedAt        DateTime      @updatedAt @map("updated_at")

  // Relations
  company    Company           @relation(fields: [companyId], references: [id])
  category   Category          @relation(fields: [categoryId], references: [id])
  images     ProductImage[]
  variants   ProductVariant[]
  attributes ProductAttribute[]
  reviews    Review[]
  wishlist   WishlistItem[]
  cartItems  CartItem[]
  orderItems OrderItem[]
  views      ProductView[]
  bulkPrices BulkPriceTier[]

  @@index([companyId])
  @@index([categoryId])
  @@index([status])
  @@index([price])
  @@index([rating])
  @@index([createdAt])
  @@index([city])
  @@index([listingType])
  @@index([isFeatured])
  @@index([isFlashDeal, flashDealEndsAt])
  @@index([name(ops: raw("gin_trgm_ops"))], type: Gin) // Full-text search
  @@map("products")
}

model ProductImage {
  id          String  @id @default(uuid()) @db.Uuid
  productId   String  @map("product_id") @db.Uuid
  url         String
  storagePath String? @map("storage_path")
  altText     String? @map("alt_text")
  isPrimary   Boolean @default(false) @map("is_primary")
  sortOrder   Int     @default(0) @map("sort_order")
  createdAt   DateTime @default(now()) @map("created_at")

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@map("product_images")
}

model ProductVariant {
  id             String  @id @default(uuid()) @db.Uuid
  productId      String  @map("product_id") @db.Uuid
  name           String  // e.g. "Red / Large"
  sku            String? @unique
  priceAdjustment Decimal @default(0) @map("price_adjustment") @db.Decimal(12, 2)
  stockQuantity  Int     @default(0) @map("stock_quantity")
  attributes     Json?   // { color: "Red", size: "Large" }
  imageUrl       String? @map("image_url")
  isActive       Boolean @default(true) @map("is_active")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  product    Product     @relation(fields: [productId], references: [id], onDelete: Cascade)
  cartItems  CartItem[]
  orderItems OrderItem[]

  @@index([productId])
  @@map("product_variants")
}

model ProductAttribute {
  id        String @id @default(uuid()) @db.Uuid
  productId String @map("product_id") @db.Uuid
  name      String @map("attribute_name")
  value     String @map("attribute_value")
  sortOrder Int    @default(0) @map("sort_order")

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@map("product_attributes")
}

model BulkPriceTier {
  id        String  @id @default(uuid()) @db.Uuid
  productId String  @map("product_id") @db.Uuid
  minQty    Int     @map("min_quantity")
  maxQty    Int?    @map("max_quantity")
  price     Decimal @db.Decimal(12, 2)

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@map("bulk_price_tiers")
}

// =============================================================
// ORDER MODULE — Orders, Sub-orders, Items, Shipments
// =============================================================

model Order {
  id              String      @id @default(uuid()) @db.Uuid
  userId          String      @map("user_id") @db.Uuid
  orderNumber     String      @unique @map("order_number")
  subtotal        Decimal     @db.Decimal(12, 2)
  deliveryFee     Decimal     @default(0) @map("delivery_fee") @db.Decimal(12, 2)
  discount        Decimal     @default(0) @db.Decimal(12, 2)
  tax             Decimal     @default(0) @db.Decimal(12, 2)
  total           Decimal     @db.Decimal(12, 2)
  currency        String      @default("ETB")
  status          OrderStatus @default(PENDING)
  notes           String?     @db.Text
  // Shipping address (snapshot)
  shippingName    String      @map("shipping_full_name")
  shippingPhone   String      @map("shipping_phone")
  shippingCity    String      @map("shipping_city")
  shippingSubCity String      @map("shipping_sub_city")
  shippingWoreda  String      @map("shipping_woreda")
  shippingHouse   String?     @map("shipping_house_number")
  shippingExtra   String?     @map("shipping_additional_info")
  addressId       String?     @map("address_id") @db.Uuid
  // Coupon
  couponId        String?     @map("coupon_id") @db.Uuid
  couponDiscount  Decimal     @default(0) @map("coupon_discount") @db.Decimal(12, 2)
  cancelReason    String?     @map("cancel_reason")
  cancelledAt     DateTime?   @map("cancelled_at")
  completedAt     DateTime?   @map("completed_at")
  createdAt       DateTime    @default(now()) @map("created_at")
  updatedAt       DateTime    @updatedAt @map("updated_at")

  user      User       @relation(fields: [userId], references: [id])
  address   Address?   @relation(fields: [addressId], references: [id])
  coupon    Coupon?    @relation(fields: [couponId], references: [id])
  subOrders SubOrder[]

  @@index([userId])
  @@index([status])
  @@index([orderNumber])
  @@index([createdAt])
  @@map("orders")
}

model SubOrder {
  id          String      @id @default(uuid()) @db.Uuid
  orderId     String      @map("order_id") @db.Uuid
  companyId   String      @map("company_id") @db.Uuid
  subtotal    Decimal     @db.Decimal(12, 2)
  deliveryFee Decimal     @default(0) @map("delivery_fee") @db.Decimal(12, 2)
  total       Decimal     @db.Decimal(12, 2)
  status      OrderStatus @default(PENDING)
  createdAt   DateTime    @default(now()) @map("created_at")
  updatedAt   DateTime    @updatedAt @map("updated_at")

  order    Order       @relation(fields: [orderId], references: [id], onDelete: Cascade)
  company  Company     @relation(fields: [companyId], references: [id])
  items    OrderItem[]
  payment  Payment?
  shipment Shipment?
  dispute  Dispute?

  @@index([orderId])
  @@index([companyId])
  @@index([status])
  @@map("sub_orders")
}

model OrderItem {
  id           String  @id @default(uuid()) @db.Uuid
  subOrderId   String  @map("sub_order_id") @db.Uuid
  productId    String  @map("product_id") @db.Uuid
  variantId    String? @map("variant_id") @db.Uuid
  // Snapshot at time of order
  productName  String  @map("product_name")
  productImage String  @map("product_image")
  variantName  String? @map("variant_name")
  unitPrice    Decimal @map("unit_price") @db.Decimal(12, 2)
  quantity     Int
  totalPrice   Decimal @map("total_price") @db.Decimal(12, 2)
  createdAt    DateTime @default(now()) @map("created_at")

  subOrder SubOrder        @relation(fields: [subOrderId], references: [id], onDelete: Cascade)
  product  Product         @relation(fields: [productId], references: [id])
  variant  ProductVariant? @relation(fields: [variantId], references: [id])

  @@index([subOrderId])
  @@index([productId])
  @@map("order_items")
}

// =============================================================
// PAYMENT MODULE
// =============================================================

model Payment {
  id                String        @id @default(uuid()) @db.Uuid
  subOrderId        String        @unique @map("sub_order_id") @db.Uuid
  userId            String        @map("user_id") @db.Uuid
  amount            Decimal       @db.Decimal(12, 2)
  currency          String        @default("ETB")
  method            PaymentMethod
  status            PaymentStatus @default(PENDING)
  transactionId     String?       @map("transaction_id")
  providerReference String?       @map("provider_reference")
  providerResponse  Json?         @map("provider_response")
  paidAt            DateTime?     @map("paid_at")
  failedAt          DateTime?     @map("failed_at")
  failureReason     String?       @map("failure_reason")
  createdAt         DateTime      @default(now()) @map("created_at")
  updatedAt         DateTime      @updatedAt @map("updated_at")

  subOrder SubOrder @relation(fields: [subOrderId], references: [id])

  @@index([userId])
  @@index([status])
  @@index([transactionId])
  @@map("payments")
}

model Settlement {
  id         String           @id @default(uuid()) @db.Uuid
  companyId  String           @map("company_id") @db.Uuid
  amount     Decimal          @db.Decimal(12, 2)
  fee        Decimal          @default(0) @db.Decimal(12, 2)
  netAmount  Decimal          @map("net_amount") @db.Decimal(12, 2)
  currency   String           @default("ETB")
  status     SettlementStatus @default(PENDING)
  periodFrom DateTime         @map("period_from")
  periodTo   DateTime         @map("period_to")
  paidAt     DateTime?        @map("paid_at")
  reference  String?
  createdAt  DateTime         @default(now()) @map("created_at")

  company Company @relation(fields: [companyId], references: [id])

  @@index([companyId])
  @@index([status])
  @@map("settlements")
}

// =============================================================
// LOGISTICS MODULE
// =============================================================

model Address {
  id             String  @id @default(uuid()) @db.Uuid
  userId         String  @map("user_id") @db.Uuid
  label          String  @default("Home")
  fullName       String  @map("full_name")
  phone          String
  city           String
  subCity        String  @map("sub_city")
  woreda         String
  houseNumber    String? @map("house_number")
  additionalInfo String? @map("additional_info")
  isDefault      Boolean @default(false) @map("is_default")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  orders Order[]

  @@index([userId])
  @@map("addresses")
}

model Shipment {
  id             String         @id @default(uuid()) @db.Uuid
  subOrderId     String         @unique @map("sub_order_id") @db.Uuid
  carrier        String?
  trackingNumber String?        @map("tracking_number")
  trackingUrl    String?        @map("tracking_url")
  status         ShipmentStatus @default(PENDING)
  estimatedAt    DateTime?      @map("estimated_delivery_at")
  shippedAt      DateTime?      @map("shipped_at")
  deliveredAt    DateTime?      @map("delivered_at")
  createdAt      DateTime       @default(now()) @map("created_at")
  updatedAt      DateTime       @updatedAt @map("updated_at")

  subOrder SubOrder         @relation(fields: [subOrderId], references: [id])
  events   ShipmentEvent[]

  @@index([trackingNumber])
  @@map("shipments")
}

model ShipmentEvent {
  id         String   @id @default(uuid()) @db.Uuid
  shipmentId String   @map("shipment_id") @db.Uuid
  status     String
  location   String?
  note       String?
  occurredAt DateTime @map("occurred_at")
  createdAt  DateTime @default(now()) @map("created_at")

  shipment Shipment @relation(fields: [shipmentId], references: [id], onDelete: Cascade)

  @@index([shipmentId])
  @@map("shipment_events")
}

// =============================================================
// REVIEW MODULE
// =============================================================

model Review {
  id                 String   @id @default(uuid()) @db.Uuid
  productId          String   @map("product_id") @db.Uuid
  userId             String   @map("user_id") @db.Uuid
  rating             Int      // 1-5
  title              String?
  comment            String?  @db.Text
  images             String[]
  isVerifiedPurchase Boolean  @default(false) @map("is_verified_purchase")
  isApproved         Boolean  @default(true) @map("is_approved")
  helpfulCount       Int      @default(0) @map("helpful_count")
  // Seller reply
  reply              String?  @db.Text
  replyAt            DateTime? @map("reply_at")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id])

  @@unique([productId, userId]) // One review per product per user
  @@index([productId])
  @@index([userId])
  @@index([rating])
  @@map("reviews")
}

// =============================================================
// CART & WISHLIST
// =============================================================

model CartItem {
  id            String   @id @default(uuid()) @db.Uuid
  userId        String   @map("user_id") @db.Uuid
  productId     String   @map("product_id") @db.Uuid
  variantId     String?  @map("variant_id") @db.Uuid
  quantity      Int      @default(1)
  savedForLater Boolean  @default(false) @map("saved_for_later")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  user    User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  product Product         @relation(fields: [productId], references: [id], onDelete: Cascade)
  variant ProductVariant? @relation(fields: [variantId], references: [id])

  @@unique([userId, productId, variantId])
  @@index([userId])
  @@map("cart_items")
}

model WishlistItem {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  productId String   @map("product_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at")

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
  @@index([userId])
  @@map("wishlists")
}

// =============================================================
// MESSAGING MODULE
// =============================================================

model Conversation {
  id                String   @id @default(uuid()) @db.Uuid
  buyerId           String   @map("buyer_id") @db.Uuid
  sellerId          String   @map("seller_id") @db.Uuid
  productId         String?  @map("product_id") @db.Uuid
  orderId           String?  @map("order_id") @db.Uuid
  buyerUnreadCount  Int      @default(0) @map("buyer_unread_count")
  sellerUnreadCount Int      @default(0) @map("seller_unread_count")
  isArchived        Boolean  @default(false) @map("is_archived")
  lastMessageAt     DateTime @default(now()) @map("last_message_at")
  createdAt         DateTime @default(now()) @map("created_at")

  buyer    User      @relation("buyer", fields: [buyerId], references: [id])
  seller   User      @relation("seller_user", fields: [sellerId], references: [id])
  messages Message[]

  @@index([buyerId])
  @@index([sellerId])
  @@index([lastMessageAt])
  @@map("conversations")
}

model Message {
  id              String        @id @default(uuid()) @db.Uuid
  conversationId  String        @map("conversation_id") @db.Uuid
  senderId        String        @map("sender_id") @db.Uuid
  content         String?       @db.Text
  messageType     String        @default("text") @map("message_type") // text, image, attachment
  imageUrl        String?       @map("image_url")
  attachmentUrl   String?       @map("attachment_url")
  attachmentName  String?       @map("attachment_name")
  status          MessageStatus @default(SENT)
  isDeleted       Boolean       @default(false) @map("is_deleted")
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender       User         @relation("sender", fields: [senderId], references: [id])

  @@index([conversationId])
  @@index([senderId])
  @@index([createdAt])
  @@map("messages")
}

// =============================================================
// NOTIFICATION MODULE
// =============================================================

model Notification {
  id        String           @id @default(uuid()) @db.Uuid
  userId    String           @map("user_id") @db.Uuid
  type      NotificationType @default(SYSTEM)
  title     String
  body      String
  actionUrl String?          @map("action_url")
  data      Json?
  isRead    Boolean          @default(false) @map("is_read")
  readAt    DateTime?        @map("read_at")
  createdAt DateTime         @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
  @@index([createdAt])
  @@map("notifications")
}

// =============================================================
// ANALYTICS MODULE
// =============================================================

model ProductView {
  id        String   @id @default(uuid()) @db.Uuid
  productId String   @map("product_id") @db.Uuid
  userId    String?  @map("user_id") @db.Uuid
  sessionId String?  @map("session_id")
  ipHash    String?  @map("ip_hash")
  referrer  String?
  createdAt DateTime @default(now()) @map("created_at")

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  user    User?   @relation(fields: [userId], references: [id])

  @@index([productId])
  @@index([createdAt])
  @@map("product_views")
}

model SearchQuery {
  id           String   @id @default(uuid()) @db.Uuid
  userId       String?  @map("user_id") @db.Uuid
  query        String
  categoryId   String?  @map("category_id") @db.Uuid
  resultsCount Int      @default(0) @map("results_count")
  sessionId    String?  @map("session_id")
  createdAt    DateTime @default(now()) @map("created_at")

  user User? @relation(fields: [userId], references: [id])

  @@index([query])
  @@index([createdAt])
  @@map("search_queries")
}

// =============================================================
// PROMOTIONS MODULE
// =============================================================

model Coupon {
  id             String    @id @default(uuid()) @db.Uuid
  code           String    @unique
  description    String?
  discountType   String    @map("discount_type") // percentage, fixed
  discountValue  Decimal   @map("discount_value") @db.Decimal(12, 2)
  minOrderAmount Decimal?  @map("min_order_amount") @db.Decimal(12, 2)
  maxDiscount    Decimal?  @map("max_discount") @db.Decimal(12, 2)
  usageLimit     Int?      @map("usage_limit")
  usedCount      Int       @default(0) @map("used_count")
  isActive       Boolean   @default(true) @map("is_active")
  startsAt       DateTime  @map("starts_at")
  expiresAt      DateTime  @map("expires_at")
  createdAt      DateTime  @default(now()) @map("created_at")

  orders Order[]

  @@index([code])
  @@index([isActive, expiresAt])
  @@map("coupons")
}

// =============================================================
// DISPUTE MODULE
// =============================================================

model Dispute {
  id          String        @id @default(uuid()) @db.Uuid
  subOrderId  String        @unique @map("sub_order_id") @db.Uuid
  companyId   String        @map("company_id") @db.Uuid
  openedBy    String        @map("opened_by") @db.Uuid
  reason      String        @db.Text
  evidence    Json?         // URLs to images/docs
  status      DisputeStatus @default(OPEN)
  resolution  String?       @db.Text
  resolvedBy  String?       @map("resolved_by") @db.Uuid
  resolvedAt  DateTime?     @map("resolved_at")
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")

  subOrder SubOrder @relation(fields: [subOrderId], references: [id])
  company  Company  @relation(fields: [companyId], references: [id])

  @@index([status])
  @@map("disputes")
}

// =============================================================
// ADMIN MODULE — Audit Logs
// =============================================================

model AuditLog {
  id         String   @id @default(uuid()) @db.Uuid
  userId     String   @map("user_id") @db.Uuid
  action     String   // e.g. "product.approve", "user.ban"
  entityType String   @map("entity_type") // "product", "company", "user"
  entityId   String   @map("entity_id") @db.Uuid
  oldData    Json?    @map("old_data")
  newData    Json?    @map("new_data")
  ipAddress  String?  @map("ip_address")
  createdAt  DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([entityType, entityId])
  @@index([createdAt])
  @@map("audit_logs")
}

// =============================================================
// SYSTEM CONFIG
// =============================================================

model SystemConfig {
  id    String @id @default(uuid()) @db.Uuid
  key   String @unique
  value Json
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("system_config")
}
